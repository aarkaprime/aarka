# Database - Neon PostgreSQL (pooled connection for serverless)
# Get your free database at https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require&connection_limit=1"
# Direct URL for migrations (non-pooled)
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Auth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# AI Provider
DEEPSEEK_API_KEY="your-deepseek-api-key"
